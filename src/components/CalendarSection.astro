// Placeholder for the Gancio-fed calendar widget that will live here later.
// For now it's a dashed drop-zone so you can see where it sits in the layout.
---
<section class="bg-base-100 py-20">
  <div class="mx-auto max-w-screen-xl px-4">
    <header class="mb-10 space-y-3 text-center">
      <h2 class="font-anton text-4xl md:text-5xl">Upcoming Distributions</h2>
      <p class="text-base-content/70 text-lg">
        Lorem ipsum — meal times, distro days, and events will list here.
      </p>
    </header>
    <div
      class="border-base-300 text-base-content/50 flex min-h-72 items-center justify-center rounded-2xl border-2 border-dashed">
      <p class="text-center text-lg">
        Calendar widget goes here<br />
        <span class="text-sm">(reads from Gancio later)</span>
      </p>
    </div>
  </div>
</section>
