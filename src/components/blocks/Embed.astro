---
import type { EmbedBlock } from './types'

const { heading, note, html }: EmbedBlock = Astro.props
---
<section class="bg-base-100 py-10">
  <div class="mx-auto max-w-3xl px-4">
    {heading && <h2 class="font-heading mb-3 text-center text-4xl md:text-5xl">{heading}</h2>}
    {note && <p class="text-base-content/70 mx-auto mb-8 max-w-2xl text-center">{note}</p>}
    {
      html ? (
        <div set:html={html} />
      ) : (
        <div class="border-base-300 text-base-content/50 flex min-h-72 items-center justify-center rounded-2xl border-2 border-dashed">
          <p class="text-center">
            Embedded form goes here.<br />
            <span class="text-sm">(paste the embed code in the CMS)</span>
          </p>
        </div>
      )
    }
  </div>
</section>
