---
import type { StepsBlock } from './types'

const { heading, subheading, items = [] }: StepsBlock = Astro.props
---
<section class="py-12">
  <div class="mx-auto max-w-screen-xl px-4">
    {
      (heading || subheading) && (
        <header class="mb-12 space-y-3 text-center">
          {heading && <h2 class="font-heading text-4xl md:text-5xl">{heading}</h2>}
          {subheading && <p class="text-base-content/70 text-lg">{subheading}</p>}
        </header>
      )
    }
    <ol class="grid gap-8 sm:grid-cols-2 md:grid-cols-4">
      {
        items.map((step, i) => (
          <li class="space-y-3">
            <div class="bg-primary text-primary-content flex h-12 w-12 items-center justify-center rounded-full text-xl font-bold">
              {i + 1}
            </div>
            <h3 class="text-xl font-semibold">{step.title}</h3>
            {step.body && <p class="text-base-content/70">{step.body}</p>}
          </li>
        ))
      }
    </ol>
  </div>
</section>
