---
import { Image } from 'astro:assets'
import Buttons from '@components/ui/Buttons.astro'
import type { HeroBlock } from './types'

const { heading, subheading, intro, image, imageAlt, buttons = [] }: HeroBlock = Astro.props
---
<div class="bg-base-200">
  <div class="hero mx-auto max-w-7xl">
    <div class="hero-content max-w-screen-2xl md:py-10">
      <div class="flex flex-col-reverse md:flex-row">
        <div class="flex flex-col items-start gap-6">
          {heading && <h1 class="font-heading max-w-3xl text-6xl">{heading}</h1>}
          {subheading && <h2 class="text-4xl font-semibold">{subheading}</h2>}
          {intro && <p class="py-3">{intro}</p>}
          {
            buttons.length > 0 && (
              <div class="flex flex-col items-center justify-center gap-4 lg:flex-row">
                <Buttons buttons={buttons} />
              </div>
            )
          }
        </div>

        {
          image && (
            <div class="w-1/2">
              <Image
                src={image}
                alt={imageAlt || 'Hero Image'}
                class="h-full w-full object-cover"
                loading="lazy"
                width={500}
                height={500}
              />
            </div>
          )
        }
      </div>
    </div>
  </div>
</div>
