---
import type { ScheduleBlock } from './types'

const {
  heading,
  subheading,
  source = 'https://calendar.souphouse.org',
  tags = 'meal, distribution',
  max = 6,
}: ScheduleBlock = Astro.props
---
<section class="bg-base-100 py-20">
  <div class="mx-auto max-w-screen-xl px-4">
    {
      (heading || subheading) && (
        <header class="mb-10 space-y-3 text-center">
          {heading && <h2 class="font-heading text-4xl md:text-5xl">{heading}</h2>}
          {subheading && <p class="text-base-content/70 text-lg">{subheading}</p>}
        </header>
      )
    }
    <div data-gancio data-view="list" data-source={source} data-tags={tags} data-max={max}>
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <li class="text-base-content/50 col-span-full py-10 text-center">Loading…</li>
      </ul>
    </div>
  </div>
</section>

<script>
  import '../../scripts/calendar.js'
</script>
