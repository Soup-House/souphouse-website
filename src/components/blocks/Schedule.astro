---
import type { ScheduleBlock } from './types'

const { heading, subheading, items = [] }: ScheduleBlock = Astro.props
---
<section class="bg-base-100 py-20">
  <div class="mx-auto max-w-screen-xl px-4">
    {
      (heading || subheading) && (
        <header class="mb-10 space-y-3 text-center">
          {heading && <h2 class="font-heading text-4xl md:text-5xl">{heading}</h2>}
          {subheading && <p class="text-base-content/70 text-lg">{subheading}</p>}
        </header>
      )
    }
    {
      items.length > 0 ? (
        <ul class="divide-base-300 border-base-300 bg-base-200 mx-auto max-w-3xl divide-y rounded-2xl border">
          {items.map((item) => (
            <li class="flex flex-col gap-1 p-5 sm:flex-row sm:items-baseline sm:gap-6">
              <div class="text-primary w-44 shrink-0 font-semibold">{item.when}</div>
              <div class="flex-1">
                {item.place && <div class="font-semibold">{item.place}</div>}
                {item.detail && <div class="text-base-content/70">{item.detail}</div>}
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <div class="border-base-300 text-base-content/50 mx-auto flex min-h-40 max-w-3xl items-center justify-center rounded-2xl border-2 border-dashed">
          <p class="text-center">Meal times and distribution days will be listed here.</p>
        </div>
      )
    }
  </div>
</section>
