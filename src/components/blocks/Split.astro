---
import { marked } from 'marked'
import type { TextBlock } from './types'

const { eyebrow, heading, body }: TextBlock = Astro.props
const bodyHtml = body ? await marked(body) : ''
---
<section class="py-12">
  <div class="mx-auto grid max-w-screen-xl items-center gap-12 px-4 md:grid-cols-2">
    <div class="space-y-4">
      {eyebrow && <p class="text-primary font-semibold tracking-widest uppercase">{eyebrow}</p>}
      {heading && <h2 class="font-heading text-4xl leading-tight md:text-5xl">{heading}</h2>}
    </div>
    {bodyHtml && <div class="prose prose-lg text-base-content/80 max-w-none" set:html={bodyHtml} />}
  </div>
</section>
