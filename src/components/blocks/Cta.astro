---
import Buttons from '@components/ui/Buttons.astro'
import type { CtaBlock } from './types'

const { heading, body, buttons = [] }: CtaBlock = Astro.props
---
<section class="bg-primary text-primary-content py-20">
  <div class="mx-auto max-w-screen-md space-y-6 px-4 text-center">
    {heading && <h2 class="font-heading text-4xl md:text-5xl">{heading}</h2>}
    {body && <p class="text-primary-content/80 text-lg">{body}</p>}
    {
      buttons.length > 0 && (
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row [&_.btn-outline]:border-primary-content [&_.btn-outline]:text-primary-content">
          <Buttons buttons={buttons} />
        </div>
      )
    }
  </div>
</section>
