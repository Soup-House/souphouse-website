---
import Buttons from '@components/ui/Buttons.astro'
import SoupIcon from '@components/ui/SoupIcon.astro'
import navbarSettings from '@settings/navbar.json';
import branding from '@settings/branding.json';

// navbar.json is plain JSON, so TS can't infer the Keystatic conditional
// field as a discriminated union — spell it out so `discriminant` narrows.
type NavLink = {
  text: string
  isDropdown:
    | { discriminant: true; value: { text: string; link: string | null; description: string }[] }
    | { discriminant: false; value: { link: string | null } }
}
type NavButton = {
  label: string
  link: string
  icon?: string
  style?: string
  type?: string
  size?: string
}

const buttons = (navbarSettings?.buttons || []) as NavButton[]
const links = (navbarSettings?.links || []) as NavLink[]
// logo is an optional Keystatic image field; cast so TS doesn't infer it
// out of the current branding.json (which may not have it set yet).
const logo = (branding.site as { logo?: string | null }).logo

---
<div class="bg-base-100/50 sticky top-0 z-50 backdrop-blur-xl">
    <div class="navbar max-w-screen-2xl mx-auto">
      <div class="navbar-start">
        <div class="dropdown">
          <div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h8m-8 6h16" />
            </svg>
          </div>
          <ul
            tabindex="0"
            class="menu menu-sm dropdown-content bg-base-100 rounded-box z-[1] mt-3 w-64 p-2 shadow">
            {links.map((link) => (
              <li>
                {link.isDropdown.discriminant ? (
                  <>
                    <span>{link.text}</span>
                    <ul class="p-2">
                      {link.isDropdown.value.map((sublink) => (
                        <li>
                          <a href={sublink.link}>{sublink.text}</a>
                        </li>
                      ))}
                    </ul>
                  </>
                ) : (
                  <a href={link.isDropdown.value.link}>{link.text}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <a href="/" aria-label={branding.site.siteName} class="btn btn-ghost gap-2 text-xl">
          {logo && <img src={logo} alt="" class="h-8 w-auto" />}
          {branding.site.siteName}
        </a>
      </div>
      <div class="navbar-center hidden lg:flex">
        <ul class="menu menu-horizontal px-1 ">
          {links.map((link, i) => (
              <>
              {i > 0 && (
                <li class="pointer-events-none hidden justify-center xl:flex" aria-hidden="true">
                  <SoupIcon kind="stelline" class="h-2.5 w-2.5 p-0 text-primary/40" />
                </li>
              )}
              <li>
                {link.isDropdown.discriminant ? (
                  <details>
                    <summary>{link.text}</summary>
                    <ul class="p-2">
                      {link.isDropdown.value.map((sublink) => (
                        <li>
                          <a href={sublink.link}>{sublink.text}</a>
                        </li>
                      ))}
                    </ul>
                  </details>
                ) : (
                  <a href={link.isDropdown.value.link}>{link.text}</a>
                )}
              </li>
              </>
            ))}
        </ul>
      </div>
      <div class="navbar-end">
        <Buttons buttons={buttons} />
      </div>
    </div>
  </div>
