<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Soup House — Coming soon</title>
    <link rel="icon" href="/images/site/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cardo:wght@400;700&family=Roboto:wght@400;500&display=swap"
    />
    <style>
      :root {
        --cream: #fbf6ec;
        --tomato: #c1432b;
        --brown: #2c2420;
        --muted: #6f635b;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; }
      body {
        background: var(--cream);
        color: var(--brown);
        font-family: 'Roboto', system-ui, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        text-align: center;
        line-height: 1.6;
      }
      main { max-width: 36rem; }
      h1 {
        font-family: 'Cardo', Georgia, serif;
        font-weight: 700;
        font-size: clamp(2.75rem, 9vw, 4.5rem);
        line-height: 1.05;
        color: var(--tomato);
      }
      .tagline {
        font-family: 'Cardo', Georgia, serif;
        font-size: clamp(1.25rem, 4vw, 1.75rem);
        margin-top: 1rem;
      }
      .status { margin-top: 2rem; font-size: 1.05rem; color: var(--muted); }
      .contact { margin-top: 1.5rem; }
      a { color: var(--tomato); }
      .org { margin-top: 3rem; font-size: 0.85rem; color: var(--muted); }
    </style>
  </head>
  <body>
    <main>
      <h1>Soup House</h1>
      <p class="tagline">We show what's possible when neighbors feed each other.</p>
      <p class="status">Our website is under construction. Check back soon.</p>
      <p class="contact">Questions? <a href="mailto:contact@souphouse.org">contact@souphouse.org</a></p>
      <p class="org">Soup House, Inc. &middot; a St. Louis nonprofit</p>
    </main>
  </body>
</html>
