---
// Numbered steps row. Play with: `md:grid-cols-4`, the numbered badge
// (`bg-primary text-primary-content`), and `gap-8`.
const steps = [
  { n: 1, title: 'Lorem', body: 'Consectetur adipiscing elit sed do eiusmod tempor.' },
  { n: 2, title: 'Ipsum', body: 'Incididunt ut labore et dolore magna aliqua minim.' },
  { n: 3, title: 'Dolor', body: 'Quis nostrud exercitation ullamco laboris nisi aliquip.' },
  { n: 4, title: 'Amet', body: 'Duis aute irure dolor in reprehenderit voluptate velit.' },
];
---
<section class="bg-base-200 py-20">
  <div class="mx-auto max-w-screen-xl px-4">
    <header class="mb-12 space-y-3 text-center">
      <h2 class="font-anton text-4xl md:text-5xl">How It Works</h2>
      <p class="text-base-content/70 text-lg">Lorem ipsum dolor sit amet consectetur.</p>
    </header>
    <ol class="grid gap-8 sm:grid-cols-2 md:grid-cols-4">
      {
        steps.map((step) => (
          <li class="space-y-3">
            <div class="bg-primary text-primary-content flex h-12 w-12 items-center justify-center rounded-full text-xl font-bold">
              {step.n}
            </div>
            <h3 class="text-xl font-semibold">{step.title}</h3>
            <p class="text-base-content/70">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
