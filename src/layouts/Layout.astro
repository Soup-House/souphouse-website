---
import '@styles/global.css'
import Navbar from '@components/Navbar.astro'
import Footer from '@components/Footer.astro'
import SoupGarnish from '@components/SoupGarnish.astro'
import { ClientRouter } from 'astro:transitions'
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'

export interface Props {
  title?: string
}

import branding from '@settings/branding.json'
import seoJson from '@settings/seo.json'
import { FONT_FAMILIES, DEFAULT_TYPOGRAPHY } from '@settings/fonts'

// seo.json is plain JSON, so TS infers only the fields currently present.
// Spell out the full Keystatic schema so optional fields (canonical, images)
// typecheck once an editor fills them in.
type SeoSettings = {
  seo: { title: string; description: string; keywords: string; canonical?: string }
  opengraph: { Title: string; Description: string; Image?: string | null }
  twitter: { Title: string; Description: string; Image?: string | null }
}
const seo = seoJson as SeoSettings

// Keystatic stores image fields as repo paths under src/assets; resolve them
// through Vite so the URL points at an asset that exists in the build output.
const seoImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/seo/**/*',
  { eager: true },
)
const seoImageUrl = (path?: string | null) =>
  path ? seoImages[path]?.default.src : undefined
const ogImage = seoImageUrl(seo.opengraph.Image)
const twitterImage = seoImageUrl(seo.twitter.Image)

const { title } = Astro.props
const fullTitle = [seo.seo.title, title].filter(Boolean).join(' | ')

const typography = { ...DEFAULT_TYPOGRAPHY, ...(branding.site.typography ?? {}) }
const headingFont =
  FONT_FAMILIES.find((f) => f.id === typography.headingFont) ??
  FONT_FAMILIES.find((f) => f.id === DEFAULT_TYPOGRAPHY.headingFont)!
const bodyFont =
  FONT_FAMILIES.find((f) => f.id === typography.bodyFont) ??
  FONT_FAMILIES.find((f) => f.id === DEFAULT_TYPOGRAPHY.bodyFont)!
const uiFont =
  FONT_FAMILIES.find((f) => f.id === typography.uiFont) ??
  FONT_FAMILIES.find((f) => f.id === DEFAULT_TYPOGRAPHY.uiFont)!
const fontHrefs = [...new Set([headingFont.href, bodyFont.href, uiFont.href])]
const fontVars = {
  '--font-heading': headingFont.stack,
  '--font-body': bodyFont.stack,
  '--font-ui': uiFont.stack,
  '--font-heading-weight': typography.headingWeight,
  '--font-body-weight': typography.bodyWeight,
}

// Theme: a light theme, a dark theme, and the default mode for first-time
// visitors — all chosen in the CMS (Site Settings → Branding). The visitor's
// own choice (theme toggle) is stored client-side and wins; see the head
// script below, which applies it before first paint to avoid a flash.
const themeSite = branding.site as {
  theme?: string
  darkTheme?: string
  defaultMode?: 'system' | 'light' | 'dark'
}
const lightTheme = themeSite.theme ?? 'souphouse'
const darkTheme = themeSite.darkTheme ?? 'souphouse-dark'
const defaultMode = themeSite.defaultMode ?? 'system'
// Server-rendered default; the head script corrects it per visitor.
const initialTheme = defaultMode === 'dark' ? darkTheme : lightTheme
---

<!doctype html>
<html lang="en" class="font-body scroll-smooth" data-theme={initialTheme} style={fontVars}>
  <head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Apply the visitor's theme before first paint (no flash), and re-apply
       after Astro view-transition navigations, which reset <html>. -->
  <script is:inline define:vars={{ lightTheme, darkTheme, defaultMode }}>
    (function () {
      function resolve() {
        try {
          var stored = localStorage.getItem('theme-mode');
          var mode = stored
            ? stored
            : defaultMode === 'system'
              ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
              : defaultMode;
          return mode === 'dark' ? darkTheme : lightTheme;
        } catch (e) {
          return lightTheme;
        }
      }
      function apply() {
        document.documentElement.setAttribute('data-theme', resolve());
      }
      window.__applyTheme = apply;
      apply();
      if (!window.__themeBound) {
        window.__themeBound = true;
        document.addEventListener('astro:after-swap', apply);
      }
    })();
  </script>

  <!-- Fonts (family + weights chosen in Site Settings -> Branding -> Typography) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {fontHrefs.map((href) => <link rel="stylesheet" href={href} />)}

  {branding.site.favicon && (
  <link rel="icon" href={branding.site.favicon} />
      )}

  <!-- SEO -->
  {fullTitle && <title>{fullTitle}</title>}
  {seo.seo.description && <meta name="description" content={seo.seo.description} />}
  {seo.seo.keywords && <meta name="keywords" content={seo.seo.keywords} />}
  {seo.seo.canonical && <link rel="canonical" href={seo.seo.canonical} />}
  
  <!-- Open Graph -->
  <meta property="og:title" content={seo.opengraph?.Title || title || seo.seo.title} />
  {seo.opengraph?.Description && (
    <meta property="og:description" content={seo.opengraph.Description} />
  )}
  {ogImage && (
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? Astro.url.origin).href} />
  )}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={seo.twitter?.Title || title || seo.seo.title} />
  {seo.twitter?.Description && (
    <meta name="twitter:description" content={seo.twitter.Description} />
  )}
  {twitterImage && (
    <meta name="twitter:image" content={new URL(twitterImage, Astro.site ?? Astro.url.origin).href} />
  )}
 
  <ClientRouter />
  </head>

  <body class="relative">
    <SoupGarnish />
    <Navbar />
    <slot />
    <Footer />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
