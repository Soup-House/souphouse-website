---
import '@styles/global.css'
import Navbar from '@components/Navbar.astro'
import Footer from '@components/Footer.astro'
import SoupGarnish from '@components/SoupGarnish.astro'
import { ClientRouter } from 'astro:transitions'
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'

export interface Props {
  title: string
}

import branding from '@settings/branding.json'
import seo from '@settings/seo.json'
import { FONT_FAMILIES, DEFAULT_TYPOGRAPHY } from '@settings/fonts'

const { title } = Astro.props

const typography = { ...DEFAULT_TYPOGRAPHY, ...(branding.site.typography ?? {}) }
const headingFont =
  FONT_FAMILIES.find((f) => f.id === typography.headingFont) ??
  FONT_FAMILIES.find((f) => f.id === DEFAULT_TYPOGRAPHY.headingFont)!
const bodyFont =
  FONT_FAMILIES.find((f) => f.id === typography.bodyFont) ??
  FONT_FAMILIES.find((f) => f.id === DEFAULT_TYPOGRAPHY.bodyFont)!
const fontHrefs = [...new Set([headingFont.href, bodyFont.href])]
const fontVars = {
  '--font-heading': headingFont.stack,
  '--font-body': bodyFont.stack,
  '--font-heading-weight': typography.headingWeight,
  '--font-body-weight': typography.bodyWeight,
}
---

<!doctype html>
<html lang="en" class="font-body scroll-smooth" data-theme={branding.site.theme} style={fontVars}>
  <head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Fonts (family + weights chosen in Site Settings -> Branding -> Typography) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {fontHrefs.map((href) => <link rel="stylesheet" href={href} />)}

  {branding.site.favicon && (
  <link rel="icon" href={branding.site.favicon} />
      )}

  <!-- SEO -->
  {seo.seo.title && <title>{seo.seo.title} | {title}</title>}
  {seo.seo.description && <meta name="description" content={seo.seo.description} />}
  {seo.seo.keywords && <meta name="keywords" content={seo.seo.keywords} />}
  {seo.seo.canonical && <link rel="canonical" href={seo.seo.canonical} />}
  
  <!-- Open Graph -->
  <meta property="og:title" content={seo.opengraph?.Title || title || seo.title} />
  {seo.opengraph?.Description && (
    <meta property="og:description" content={seo.opengraph.Description} />
  )}
  {seo.opengraph?.Image?.src && (
    <meta property="og:image" content={new URL(seo.opengraph.Image.src, Astro.url.origin)} />
  )}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={seo.twitter?.Title || title || seo.title} />
  {seo.twitter?.Description && (
    <meta name="twitter:description" content={seo.twitter.Description} />
  )}
  {seo.twitter?.Image?.src && (
    <meta name="twitter:image" content={new URL(seo.twitter.Image.src, Astro.url.origin)} />
  )}
 
  <ClientRouter />
  </head>

  <body class="relative">
    <SoupGarnish />
    <Navbar />
    <slot />
    <Footer />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
